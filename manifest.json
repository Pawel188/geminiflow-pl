{
  "manifest_version": 2,
  "name": "GeminiFlow",
  "version": "2.2.0",
  "description": "Zaawansowane narzędzia dla Google Gemini: zarządzanie czatami, eksport, masowe zmienianie nazw, prompty z kategoriami i inne.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "storage",
    "https://gemini.google.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "geminiflow@francisco.dev",
      "strict_min_version": "79.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    "popup/toolbox.html",
    "popup/toolbox.js",
    "popup/toolbox.css"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "GeminiFlow",
    "default_popup": "popup/popup.html"
  }
}